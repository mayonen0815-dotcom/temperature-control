generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Store {
  id        String   @id @default(cuid())
  storeCode String   @unique
  name      String
  pinHash   String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  equipments             Equipment[]
  temperatureLogs        TemperatureLog[]
  temperatureSubmissions TemperatureSubmission[]
  complaints             Complaint[]
  documents              Document[]
  checklistGroups        ChecklistGroup[]
  checklistAnswers       ChecklistAnswer[]
  checklistSubmissions   ChecklistSubmission[]
  employees              Employee[]
}

model Equipment {
  id       String  @id @default(cuid())
  storeId  String
  store    Store   @relation(fields: [storeId], references: [id])
  name     String
  minTemp  Float
  maxTemp  Float
  sortOrder Int    @default(0)
  active   Boolean @default(true)

  temperatureLogs TemperatureLog[]

  @@index([storeId])
}

enum Period {
  AM
  PM
}

model TemperatureLog {
  id          String   @id @default(cuid())
  storeId     String
  store       Store    @relation(fields: [storeId], references: [id])
  equipmentId String
  equipment   Equipment @relation(fields: [equipmentId], references: [id])
  logDate     DateTime
  period      Period
  value       Float
  isAbnormal  Boolean  @default(false)
  note        String?
  staffName   String
  editedByAdmin Boolean @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([storeId, logDate])
  @@unique([equipmentId, logDate, period])
}

model TemperatureSubmission {
  id           String   @id @default(cuid())
  storeId      String
  store        Store    @relation(fields: [storeId], references: [id])
  logDate      DateTime
  period       Period
  submittedBy  String
  submittedByAdmin Boolean @default(false)
  submittedAt  DateTime @default(now())

  @@unique([storeId, logDate, period])
  @@index([storeId, logDate])
}

enum ComplaintStatus {
  NEW
  IN_PROGRESS
  DONE
}

model Complaint {
  id             String          @id @default(cuid())
  storeId        String
  store          Store           @relation(fields: [storeId], references: [id])
  title          String
  detail         String
  photoUrl       String?
  status         ComplaintStatus @default(NEW)
  staffName      String
  createdByAdmin Boolean         @default(false)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@index([storeId])
}

enum DocumentStatus {
  SUBMITTED
  APPROVED
  REJECTED
}

model Document {
  id         String         @id @default(cuid())
  storeId    String
  store      Store          @relation(fields: [storeId], references: [id])
  staffName  String
  docType    String
  fileUrl    String
  fileName   String
  status     DocumentStatus @default(SUBMITTED)
  note       String?
  createdAt  DateTime       @default(now())

  @@index([storeId])
}

model ChecklistGroup {
  id                String   @id @default(cuid())
  storeId           String
  store             Store    @relation(fields: [storeId], references: [id])
  name              String
  referencePhotoUrl String?
  sortOrder         Int      @default(0)
  active            Boolean  @default(true)

  items ChecklistItem[]

  @@index([storeId])
}

model ChecklistItem {
  id        String   @id @default(cuid())
  groupId   String
  group     ChecklistGroup @relation(fields: [groupId], references: [id])
  name      String
  guide     String?
  sortOrder Int      @default(0)
  active    Boolean  @default(true)

  answers ChecklistAnswer[]

  @@index([groupId])
}

model ChecklistAnswer {
  id            String   @id @default(cuid())
  itemId        String
  item          ChecklistItem @relation(fields: [itemId], references: [id])
  storeId       String
  store         Store    @relation(fields: [storeId], references: [id])
  logDate       DateTime
  passed        Boolean
  photoUrl      String?
  note          String?
  staffName     String
  editedByAdmin Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([itemId, logDate])
  @@index([storeId, logDate])
}

model ChecklistSubmission {
  id               String   @id @default(cuid())
  storeId          String
  store            Store    @relation(fields: [storeId], references: [id])
  logDate          DateTime
  staffCondition   String
  absenceNote      String?
  confirmedBy      String
  submittedBy      String
  submittedByAdmin Boolean  @default(false)
  submittedAt      DateTime @default(now())

  @@unique([storeId, logDate])
  @@index([storeId, logDate])
}

model Employee {
  id         String    @id @default(cuid())
  storeId    String
  store      Store     @relation(fields: [storeId], references: [id])
  name       String
  address    String?
  hireDate   DateTime?
  resignDate DateTime?
  note       String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([storeId])
}

model AdminUser {
  id           String @id @default(cuid())
  name         String
  passwordHash String
}
