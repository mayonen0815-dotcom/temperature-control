# Vercel Postgres / Neon などの接続文字列
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# Cookieの署名に使うランダムな文字列（32文字以上のランダム文字列を推奨）
SESSION_SECRET="please-change-this-to-a-random-string"

# Vercel Blob Storage のトークン（写真・書類アップロード用）
# Vercelダッシュボード → Storage → Blob を作成すると自動で発行されます
BLOB_READ_WRITE_TOKEN=""

# 初期管理者アカウント（`npm run db:seed` 実行時のみ使用）
SEED_ADMIN_NAME="admin"
SEED_ADMIN_PASSWORD="changeme123"
